generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SourceType {
  publication
  scenario
  edit
  external
}

enum ApprovalStatus {
  pending
  approved
  rejected
  canceled
}

enum AuditAction {
  created
  approved
  rejected
  canceled
}

model ApprovalRequest {
  id              String          @id @default(uuid()) @db.Uuid
  workspaceId     String
  sourceType      SourceType
  sourceId        String
  title           String
  description     String?
  status          ApprovalStatus  @default(pending)
  reviewerUserIds String[]
  createdByUserId String
  decidedByUserId String?
  decisionComment String?
  decisionReason  String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  decidedAt       DateTime?
  auditLog        AuditLogEntry[]

  @@index([workspaceId, createdAt])
  @@index([workspaceId, status])
  @@map("approval_requests")
}

model IdempotencyKey {
  id             String   @id @default(uuid()) @db.Uuid
  workspaceId    String
  userId         String
  key            String
  fingerprint    String
  responseStatus Int
  responseBody   Json
  createdAt      DateTime @default(now())

  @@unique([workspaceId, userId, key])
  @@map("idempotency_keys")
}

model AuditLogEntry {
  id          String          @id @default(uuid()) @db.Uuid
  workspaceId String
  requestId   String          @db.Uuid
  request     ApprovalRequest @relation(fields: [requestId], references: [id])
  actorUserId String
  action      AuditAction
  details     Json
  createdAt   DateTime        @default(now())

  @@index([requestId])
  @@map("audit_log")
}

model OutboxEvent {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String
  eventType   String
  payload     Json
  createdAt   DateTime  @default(now())
  publishedAt DateTime?

  @@index([publishedAt])
  @@map("outbox_events")
}
